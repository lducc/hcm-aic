# macOS only: faiss-cpu and torch each bundle their own OpenMP runtime, which crashes
# the process (SIGABRT/SIGSEGV) as soon as both are loaded together. This forces a
# single-threaded OpenMP runtime so they can coexist.
KMP_DUPLICATE_LIB_OK=TRUE
OMP_NUM_THREADS=1

# Required only for BEiT-3 search.
AIC_BEIT3_HOME=/absolute/path/to/AIC/models/beit3
AIC_BEIT3_CHECKPOINT=/absolute/path/to/AIC/models/beit3_large_patch16_384_coco_retrieval.pth
AIC_BEIT3_SPM=/absolute/path/to/AIC/models/beit3.spm

# Required only for --enhance.
# GEMINI_API_KEY=

# Optional OCR engine selection for on-frame text search. Defaults shown.
# AIC_OCR_ENGINE=paddleocr   # or: tesseract
# AIC_OCR_LANG=vi            # paddleocr lang code; tesseract uses e.g. vie+eng
